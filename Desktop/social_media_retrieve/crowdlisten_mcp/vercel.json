{
  "version": 2,
  "buildCommand": "echo 'Using serverless functions only'",
  "framework": null,
  "functions": {
    "api/mcp.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 30
    },
    "api/*.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/mcp", "dest": "/api/mcp.js" },
    { "src": "/\\.well-known/oauth-protected-resource", "dest": "/api/oauth.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}