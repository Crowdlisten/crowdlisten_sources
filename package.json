{
  "name": "crowdlisten",
  "version": "2.0.0",
  "description": "Cross-channel feedback retrieval for AI agents — extract audience signal from Reddit, YouTube, TikTok, Twitter/X, and Instagram. Analysis via CrowdListen API.",
  "main": "dist/index.js",
  "bin": {
    "crowdlisten": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/index.js",
    "start:cli": "node dist/cli.js",

    "dev": "tsx src/cli.ts",
    "test": "jest",
    "test:e2e": "jest --config jest.config.e2e.js",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --forceExit",
    "audit": "npm audit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@the-convocation/twitter-scraper": "^0.22.1",
    "axios": "^1.13.1",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.4",
    "jest": "^30.2.0",
    "playwright": "^1.58.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "social-media",
    "crowd-intelligence",
    "reddit",
    "youtube",
    "tiktok",
    "twitter",
    "instagram",
    "mcp",
    "cli",
    "ai-agents"
  ],
  "author": "CrowdListen Team",
  "license": "MIT"
}
