{
  "name": "crowdlisten_mcp",
  "version": "1.0.0",
  "description": "CrowdListen MCP server for social media content retrieval and analysis across multiple platforms",
  "main": "api/mcp.js",
  "scripts": {
    "build": "echo 'Using streamlined JavaScript implementation - no build needed'",
    "build:watch": "tsc --watch",
    "start": "echo 'MCP Server ready at /api/mcp'",
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "test": "node test_mcp.js",
    "audit": "npm audit",
    "verify:tiktok-url-flow": "node scripts/verify-tiktok-url-flow.cjs",
    "verify:comment-analysis": "node test-comment-analysis.cjs",
    "verify:tiktok-comment-analysis": "node test-comment-intelligence.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@the-convocation/twitter-scraper": "^0.22.1",
    "axios": "^1.13.1",
    "dotenv": "^17.3.1",
    "instagram-private-api": "^1.46.1",
    "node-fetch": "^3.3.2",
    "openai": "^6.22.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.4",
    "playwright": "^1.58.2",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "mcp",
    "social-media",
    "tiktok",
    "twitter",
    "reddit",
    "instagram",
    "crowdlisten"
  ],
  "author": "CrowdListen Team",
