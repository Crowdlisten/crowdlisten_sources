# CrowdListen MCP Server - Environment Configuration
# Copy this file to .env and fill in your credentials

# ================================
# TWITTER/X API CREDENTIALS
# ================================
# Required for Twitter functionality
# Get these from: https://developer.twitter.com/en/portal/dashboard
# 1. Apply for Twitter Developer Account
# 2. Create an App
# 3. Generate API Keys and Access Tokens

TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_KEY_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here

# ================================
# INSTAGRAM CREDENTIALS
# ================================
# Required for Instagram functionality
# Use your Instagram account credentials
# ⚠️ Consider creating a dedicated account for API access
# ⚠️ May trigger Instagram security checks - use responsibly

INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# ================================
# TIKTOK CONFIGURATION
# ================================
# Optional but recommended for enhanced TikTok functionality
# MS Token: Extract from browser cookies when logged into TikTok
# 1. Open TikTok in browser and log in
# 2. Open Developer Tools (F12) → Application → Cookies
# 3. Copy the 'msToken' value

TIKTOK_MS_TOKEN=your_tiktok_ms_token_here

# Optional: Proxy configuration if needed for your region
# TIKTOK_PROXY=http://your_proxy_server:port

# ================================
# REDDIT CONFIGURATION  
# ================================
# No credentials required!
# Reddit functionality works with public access for reading content

# ================================
# YOUTUBE DATA API v3
# ================================
# Required for YouTube functionality
# Get your API key from: https://console.cloud.google.com/apis/credentials
# 1. Create a project (or select existing)
# 2. Enable "YouTube Data API v3" under APIs & Services > Library
# 3. Create an API key under APIs & Services > Credentials
# Free tier: 10,000 quota units/day (search costs 100 units each)

YOUTUBE_API_KEY=your_youtube_api_key_here

# ================================
# OPENAI API CONFIGURATION
# ================================
# Required for opinion theme clustering analysis
# Get your API key from: https://platform.openai.com/api-keys
# Used for comment clustering and sentiment analysis

OPENAI_API_KEY=your_openai_api_key_here

# ================================
# ANTHROPIC API CONFIGURATION
# ================================
# Required for Module 1: TikTok browser search — Claude Vision selects the
# most relevant videos from a screenshot of TikTok search results.
# Get your API key from: https://console.anthropic.com/

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ================================
# GOOGLE GEMINI API CONFIGURATION
# ================================
# Required for Module 3: Video understanding — Gemini 1.5 Pro receives the
# downloaded video file directly and returns structured content analysis.
# Get your API key from: https://aistudio.google.com/app/apikey

GEMINI_API_KEY=your_gemini_api_key_here

# ================================
# TIKTOK BROWSER SEARCH CONFIGURATION
# ================================
# Optional: Path to a persistent Chrome profile directory.
# When set, Playwright reuses your existing TikTok login session, which avoids
# bot detection and login walls on TikTok search pages.
#
# macOS default Chrome profile path:
# TIKTOK_CHROME_PROFILE_PATH=/Users/YOUR_USERNAME/Library/Application Support/Google/Chrome/Default
#
# Instructions:
# 1. Log into TikTok in your regular Chrome browser
# 2. Copy the path above (replace YOUR_USERNAME with your macOS username)
# 3. Paste it as the value below — Playwright will reuse that session

# TIKTOK_CHROME_PROFILE_PATH=/Users/YOUR_USERNAME/Library/Application Support/Google/Chrome/Default

# ================================
# SERVER CONFIGURATION
# ================================
# Optional: Adjust these settings if needed

# Global timeout for API requests (milliseconds)
# GLOBAL_TIMEOUT=30000

# Number of retries for failed requests
# GLOBAL_RETRIES=3

# Fallback strategy when platforms fail: 'fail', 'continue', 'mock'
# FALLBACK_STRATEGY=continue

# ================================
# LOGGING CONFIGURATION
# ================================
# Optional: Set logging level

# LOG_LEVEL=info
# LOG_FILE=crowdlisten-mcp.log

# ================================
# NOTES
# ================================
# - At least one platform must be configured for the server to start
# - Twitter requires developer account approval (1-2 days)
# - Instagram may flag automated access - use dedicated account
# - TikTok works without credentials but with limited functionality
# - Reddit requires no setup - works immediately
#
# For detailed setup instructions, see README.md